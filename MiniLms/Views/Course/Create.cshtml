@model MiniLms.Models.Course

@{
    ViewData["Title"] = "Yeni Ders Oluştur";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-journal-plus"></i> Yeni Ders Aç</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CourseCode" class="form-label fw-bold">Ders Kodu</label>
                            <input asp-for="CourseCode" class="form-control" placeholder="Örn: SE101" />
                            <span asp-validation-for="CourseCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Ders Adı</label>
                            <input asp-for="Title" class="form-control" placeholder="Örn: Yazılıma Giriş" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Ders Açıklaması</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Ders içeriği hakkında kısa bilgi..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Credits" class="form-label fw-bold">Kredi (AKTS)</label>
                            <input asp-for="Credits" class="form-control" type="number" min="1" max="10" value="5" />
                            <span asp-validation-for="Credits" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
                            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Dersi Aç</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}