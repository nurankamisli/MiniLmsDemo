@model IEnumerable<MiniLms.Models.Course>

@{
    ViewData["Title"] = "Ders Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary"><i class="bi bi-book-half"></i> Ders Listesi</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Yeni Ders Ekle</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Açıklama</th>
                        <th>Kredi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Sistemde henüz açılmış bir ders bulunmamaktadır.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-danger">@item.CourseCode</td>
                                <td>@item.Title</td>
                                <td>@item.Description</td>
                                <td><span class="badge bg-secondary">@item.Credits AKTS</span></td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning text-white"><i class="bi bi-pencil-square"></i> Düzenle</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white"><i class="bi bi-eye"></i> Detay</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="bi bi-trash"></i> Sil</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>