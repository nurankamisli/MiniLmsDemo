@model MiniLms.Models.Enrollment

@{
    ViewData["Title"] = "Yeni Ders Kaydı";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-journal-check"></i> Öğrenciyi Derse Kaydet</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                @ViewData.ModelState[string.Empty]?.Errors[0].ErrorMessage
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-bold">Öğrenci Seçin (Öğrenci No)</label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId">
                                <option value="">-- Öğrenci Seçiniz --</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CourseId" class="form-label fw-bold">Ders Seçin (Ders Kodu)</label>
                            <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId">
                                <option value="">-- Ders Seçiniz --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
                            <button type="submit" class="btn btn-success"><i class="bi bi-plus-circle"></i> Kaydı Tamamla</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}