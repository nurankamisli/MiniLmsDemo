@model MiniLms.Models.Enrollment

@{
    ViewData["Title"] = "Ders Kaydını Sil";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Ders Kaydını Silmek İstediğinize Emin Misiniz?</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-4">Aşağıdaki öğrencinin bu ders ile olan kayıt bağı kalıcı olarak silinecektir.</p>

                    <dl class="row">
                        <dt class="col-sm-4 fw-bold text-secondary">Öğrenci No:</dt>
                        <dd class="col-sm-8">@Model.Student?.StudentNumber</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Öğrenci:</dt>
                        <dd class="col-sm-8">@Model.Student?.FirstName @Model.Student?.LastName</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Ders Kodu:</dt>
                        <dd class="col-sm-8 fw-bold text-danger">@Model.Course?.CourseCode</dd>

                        <dt class="col-sm-4 fw-bold text-secondary">Ders Adı:</dt>
                        <dd class="col-sm-8">@Model.Course?.Title</dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Vazgeç</a>
                            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Ders Kaydını Sil</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>