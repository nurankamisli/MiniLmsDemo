@model IEnumerable<MiniLms.Models.Enrollment>

@{
    ViewData["Title"] = "Ders Kayıt Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary"><i class="bi bi-person-lines-fill"></i> Ders Kayıt Listesi</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Yeni Ders Kaydı Yap</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Öğrenci Numarası</th>
                        <th>Öğrenci Adı Soyadı</th>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Sistemde henüz ders kaydı yapmış bir öğrenci bulunmamaktadır.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@item.Student?.StudentNumber</td>
                                <td>@item.Student?.FirstName @item.Student?.LastName</td>
                                <td class="fw-bold text-danger">@item.Course?.CourseCode</td>
                                <td>@item.Course?.Title</td>
                                <td>@item.EnrollmentDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-center">
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Kaydı Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>