@model MiniLms.ViewModels.StudentCreateViewModel

@{
    ViewData["Title"] = "Yeni Öğrenci Oluştur";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> Yeni Öğrenci Ekle</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="StudentNumber" class="form-label fw-bold">Öğrenci Numarası</label>
                            <input asp-for="StudentNumber" class="form-control" placeholder="Örn: 220706001" />
                            <span asp-validation-for="StudentNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label fw-bold">Adı</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Örn: Ahmet" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label fw-bold">Soyadı</label>
                            <input asp-for="LastName" class="form-control" placeholder="Örn: Yılmaz" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">E-posta Adresi</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="Örn: ahmet@ogrenci.edu.tr" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
                            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Öğrenciyi Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}