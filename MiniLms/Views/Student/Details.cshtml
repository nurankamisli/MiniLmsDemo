@model MiniLms.Models.Student

<h2>Öğrenci Detayı</h2>

<hr />

<dl class="row">

    <dt class="col-sm-3">Ad</dt>
    <dd class="col-sm-9">@Model.FirstName</dd>

    <dt class="col-sm-3">Soyad</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Numara</dt>
    <dd class="col-sm-9">@Model.StudentNumber</dd>

</dl>

<a asp-action="Index" class="btn btn-primary">
    Geri Dön
</a>