@model IEnumerable<MiniLms.Models.Student>

@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary"><i class="bi bi-people-fill"></i> Öğrenci Listesi</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Yeni Öğrenci Ekle</a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Öğrenci Numarası</th>
                        <th>Adı</th>
                        <th>Soyadı</th>
                        <th>E-posta</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Sistemde henüz kayıtlı bir öğrenci bulunmamaktadır.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@item.StudentNumber</td>
                                <td>@item.FirstName</td>
                                <td>@item.LastName</td>
                                <td>@item.Email</td>
                               
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning text-white"><i class="bi bi-pencil-square"></i> Düzenle</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white"><i class="bi bi-eye"></i> Detay</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="bi bi-trash"></i> Sil</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>